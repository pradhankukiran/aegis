# Aegis reverse proxy.
# Per plan §7 — two subdomains in front of Conduit (Matrix) and strfry (Nostr).
# For local dev, set AEGIS_DOMAIN=localhost and Caddy will use its internal CA.
#
# Historical note: a third `ssb.<domain>` block once fronted the SSB
# browser-bridge pub. The pub was retired in favour of Matrix + Nostr only
# (see docs/architecture.md). If a future peer-mesh primitive arrives, add
# its block here.

{
	email {$LETSENCRYPT_EMAIL}
}

matrix.{$AEGIS_DOMAIN} {
	# Matrix Client-Server API + .well-known if the homeserver serves it.
	reverse_proxy conduit:6167
}

relay.{$AEGIS_DOMAIN} {
	# Nostr WebSocket relay (strfry).
	reverse_proxy strfry:7777
}
