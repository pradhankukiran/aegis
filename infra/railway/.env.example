# Aegis Railway env template.
# Set these in the Railway dashboard (per-service Variables tab) — Railway
# injects them at runtime. You do NOT need AEGIS_DOMAIN or LETSENCRYPT_EMAIL
# here: those were Caddy concerns in the self-hosted stack, and Caddy is gone.
# Railway terminates TLS for every `*.up.railway.app` URL automatically.

# Registration gate for the Conduit homeserver. Must match the value of
# AEGIS_MATRIX_REGISTRATION_TOKEN you set in Vercel — otherwise the in-app
# registration flow can't sign users into the homeserver.
CONDUIT_REGISTRATION_TOKEN=changeme

# OPTIONAL — pin Conduit's server_name to a custom hostname.
# Defaults to ${RAILWAY_PUBLIC_DOMAIN} (the auto-issued `*.up.railway.app` URL)
# at boot, but Conduit treats server_name as immutable: changing it later
# invalidates existing room state. Set this once, on first deploy, and never
# change it. If you attach a custom domain to the conduit service later,
# set this to that hostname before first user signup.
#
# AEGIS_CONDUIT_PUBLIC_HOSTNAME=matrix.example.com

# RAILWAY-INJECTED (do not set manually — Railway provides these at runtime):
#   RAILWAY_PUBLIC_DOMAIN     — e.g. aegis-conduit-production.up.railway.app
#   RAILWAY_PRIVATE_DOMAIN    — e.g. conduit.railway.internal
#   RAILWAY_SERVICE_NAME      — e.g. conduit
#   RAILWAY_ENVIRONMENT_NAME  — e.g. production
