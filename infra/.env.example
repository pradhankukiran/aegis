# Aegis infra environment template.
# Copy to .env and edit. The compose file substitutes ${VAR} from this file at `docker compose up` time.

# Public domain that subdomains attach to (matrix., relay., ssb.).
# For local dev: AEGIS_DOMAIN=localhost (Caddy will use its internal CA).
AEGIS_DOMAIN=aegis.app

# Email used by Caddy for Let's Encrypt account registration.
LETSENCRYPT_EMAIL=admin@aegis.app

# Optional registration gate for the Conduit homeserver.
# Conduit reads this and requires it as the `registration_token` in /_matrix/client/v3/register.
CONDUIT_REGISTRATION_TOKEN=changeme
