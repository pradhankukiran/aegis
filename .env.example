# Aegis — environment variables
# Copy to .env.local and fill in. Never commit .env.local.

# --- IPFS pinning (Pinata) ---
# Used by Beacon (dead-man's broadcast) and Crucible (whistleblower drop)
# for encrypted-blob persistence. If unset, those features degrade to
# local-only persistence and the /api/pinata/upload-url endpoint returns
# 503. JWT is server-only; gateway needs both a server-side and a
# NEXT_PUBLIC_ copy (server constructs fetch URLs; browser fetches CIDs).
PINATA_JWT=                            # server-only Pinata API key (https://app.pinata.cloud/keys)
PINATA_GATEWAY=                        # server-side gateway hostname (e.g. yourname.mypinata.cloud)
NEXT_PUBLIC_PINATA_GATEWAY=            # same value as PINATA_GATEWAY, exposed to browser
# Optional comma-separated allowlist of 64-char x-only pubkey hexes that
# may request signed upload URLs. If unset, any caller with a valid
# BIP-340 Schnorr signature is accepted (portfolio-mode default).
PINATA_ALLOWLIST=

# --- Matrix ---
# Server-only registration token. Held server-only so it's never bundled
# into the client JS (SEC-004). The /api/matrix/register route proxies
# homeserver registration with this token; if unset, that route returns
# 503 and Matrix-backed transports cannot register new accounts (existing
# stored sessions still work).
AEGIS_MATRIX_REGISTRATION_TOKEN=
# Homeserver URL the /api/matrix/register route targets. Server-only.
AEGIS_MATRIX_HOMESERVER_URL=https://matrix.aegis.app
# Homeserver URL the BROWSER uses for matrix-js-sdk (post-registration).
# Usually the same as AEGIS_MATRIX_HOMESERVER_URL above.
NEXT_PUBLIC_AEGIS_MATRIX_HOMESERVER_URL=https://matrix.aegis.app

# --- Scuttlebutt ---
# WebSocket URL for the Aegis ssb-pub bridge endpoint. Browser-only.
NEXT_PUBLIC_AEGIS_SSB_URL=wss://ssb.aegis.app/aegis-ws

# --- Public app URL ---
# Used to construct share links (Witness proof URLs, Crucible drop IDs,
# Quorum poll links). Set to your deploy URL in production.
NEXT_PUBLIC_APP_URL=http://localhost:3000
