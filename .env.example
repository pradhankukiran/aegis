# Aegis — environment variables
# Copy to .env.local and fill in. Never commit .env.local.

# --- IPFS pinning (Pinata) ---
# Used by Beacon (dead-man's broadcast) and Crucible (whistleblower drop)
# for encrypted-blob persistence. If unset, those features degrade to
# local-only persistence and the /api/pinata/upload-url endpoint returns
# 503.
PINATA_JWT=                            # server-only Pinata API key (https://app.pinata.cloud/keys)
NEXT_PUBLIC_PINATA_GATEWAY=https://gateway.pinata.cloud   # public IPFS gateway
# Optional comma-separated allowlist of 64-char x-only pubkey hexes that
# may request signed upload URLs. If unset, any caller with a valid
# BIP-340 Schnorr signature is accepted (portfolio-mode default).
PINATA_ALLOWLIST=

# --- Matrix (server-side only — never NEXT_PUBLIC_*) ---
# Registration token for the Aegis homeserver. Held server-only so it's
# never bundled into the client JS (SEC-004). The /api/matrix/register
# route proxies homeserver registration with this token; if unset, that
# route returns 503 and Matrix-backed transports cannot register new
# accounts (existing stored sessions still work).
AEGIS_MATRIX_REGISTRATION_TOKEN=
# Homeserver URL the /api/matrix/register route targets. Server-only;
# the client uses NEXT_PUBLIC_AEGIS_MATRIX_HOMESERVER for its own
# (post-registration) calls.
AEGIS_MATRIX_HOMESERVER_URL=https://matrix.aegis.app
